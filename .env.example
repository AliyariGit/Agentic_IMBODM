# Azure OpenAI — required for cloud LLM mode
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4

# IBM ODM Rule Execution Server
# Point to your real ODM instance or leave as-is for the mock server
ODM_ENDPOINT=http://localhost:8080/api/authorize

# LLM mode: "azure" | "ollama"
LLM_MODE=azure

# Ollama settings (used when LLM_MODE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3
